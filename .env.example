# SlideArabi 1.0.0 — Environment Variables
# Copy to .env for local dev, or set in Railway dashboard
# ─────────────────────────────────────────────────────────

# Translation API Keys (REQUIRED)
OPENAI_API_KEY=sk-proj-...
ANTHROPIC_API_KEY=sk-ant-api03-...

# Visual QA (REQUIRED for Phase 6)
GEMINI_API_KEY=AIza...

# Stripe (REQUIRED for payments)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...

# Optional: Stripe webhook secret for async payment confirmation
STRIPE_WEBHOOK_SECRET=whsec_...
